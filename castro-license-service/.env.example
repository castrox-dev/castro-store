# Discord
DISCORD_TOKEN=seu_token_do_bot
DISCORD_CLIENT_ID=id_da_aplicacao_discord
DISCORD_GUILD_ID=id_do_servidor_discord_opcional_registro_rapido

# Quem pode gerar licenças (IDs separados por vírgula)
STAFF_ROLE_IDS=
BUYER_ROLE_IDS=

# Rate limit: gerações por hora por usuário (não-staff)
GENERATE_RATE_LIMIT_PER_HOUR=3

# Webhook de auditoria (opcional)
AUDIT_WEBHOOK_URL=

# API HTTP (FiveM chama este endpoint)
API_HOST=0.0.0.0
API_PORT=3847
LICENSE_API_SECRET=troque_por_um_segredo_longo_aleatorio

# Pepper V3 — MESMO valor usado nos resources (não altere sem regenerar todas as chaves)
LICENSE_PEPPER=NW_LIC_V3_2026

# SQLite
DATABASE_PATH=./data/licenses.db
